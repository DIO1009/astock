# AStock 云服务器环境变量模板
# 用法：
#   cp config/server.env.example config/server.env
#   vim config/server.env          # 按注释修改
#   set -a && source config/server.env && set +a
#   bash scripts/start_server.sh
#
# systemd 用法见 docs/部署手册.md 第 7 节（EnvironmentFile=）

# ── 数据源 ────────────────────────────────────────────────────────────────────
# 1 = 东方财富实时行情（云服务器生产推荐）
# 0 = 本地 CSV 回放（需 real_market_data.csv 或 ASTOCK_DATA_PATH）
ASTOCK_LIVE_DATA=1

# 回放模式专用：指定 CSV 路径（实时模式下无效）
# ASTOCK_DATA_PATH=/home/astock/astock_trade/real_market_data.csv

# Tick 间隔（秒）。start_server.sh 默认 300（5 分钟）
ASTOCK_TICK_SECONDS=300

# ── 数据库（强烈建议配置）────────────────────────────────────────────────────
# 设为 "-" 可完全禁用 DB（无持久化、无动态选股、无日报）
ASTOCK_DB_DSN=postgres://astock:请修改密码@127.0.0.1:5432/astock_trade?sslmode=disable

# ── 选股模式 ──────────────────────────────────────────────────────────────────
# 动态选股：需 DB +（实时模式自动启用，或显式设 1）
ASTOCK_DYNAMIC_SCREENER=1

# 动态候选池 Top-N（写入 alpha_rankings 的 Layer2 数量）
ASTOCK_TOP_N=100

# Layer1 初筛数量（仅内置调度器 / alpha_scheduler 使用）
ASTOCK_TOP_LAYER1=200

# 全市场扫描超时（秒）
ASTOCK_SCAN_TIMEOUT=300

# 最大同时持仓数
ASTOCK_MAX_POS=10

# ── 东方财富实时行情限频（避免 EOF/连接被掐）────────────────────────────────
# 两次 HTTP 请求最小间隔（毫秒）。start_server.sh 默认 1000
ASTOCK_EM_MIN_INTERVAL_MS=1000
# 并发拉取数。start_server.sh 默认 2
ASTOCK_EM_MAX_CONCURRENCY=2

# 1 = 包含创业板(300/301)和科创板(688/689)；默认排除（多数散户无权限）
# ASTOCK_INCLUDE_ALL_BOARDS=0

# ── 轮动调仓（可选）──────────────────────────────────────────────────────────
ASTOCK_ROTATION_ENABLED=0
# ASTOCK_ROTATION_START=09:45
# ASTOCK_ROTATION_WATCH_RANK=70
# ASTOCK_ROTATION_EXIT_RANK=85
# ASTOCK_ROTATION_CONFIRM_TICKS=3
# ASTOCK_ROTATION_CONFIRM_DAYS=2
# ASTOCK_ROTATION_DELTA=0.10
# ASTOCK_ROTATION_LOSS_MULT=1.5
# ASTOCK_MAX_ROTATION_PER_DAY=3

# ── 调试（生产勿开）──────────────────────────────────────────────────────────
# FACTOR_DIAG=1
